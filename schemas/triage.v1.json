{
  "type": "object",
  "properties": {
    "priority": {
      "type": "string",
      "pattern": "^(Urgent|Standard|Archive)$"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}:\\d{2}$"
          },
          "type": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          }
        },
        "required": ["timestamp", "type", "confidence"]
      }
    },
    "reasoning": {
      "type": "string"
    }
  },
  "required": ["priority", "events", "reasoning"]
}
